# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_code_review?schema=public

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-secret
JWT_REFRESH_SECRET=change-me-to-another-strong-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── AI Provider ─────────────────────────────────────────
# Options: gemini | openai | anthropic | local
AI_PROVIDER=gemini

# ─── Google Gemini (recommended – free tier) ─────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# ─── OpenAI (fallback) ──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.1

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Queue ───────────────────────────────────────────────
QUEUE_CONCURRENCY=3

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── GitHub Webhooks ─────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your-webhook-secret
